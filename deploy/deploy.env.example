# UniChat Deploy Configuration
# Copy to .env or set as CI secrets.
# Two modes: SSH alias (local) or user@host (CI).

# --- SSH config alias mode (local deploy.sh) ---
# 设 DEPLOY_HOST 为 ~/.ssh/config 中的 Host 名称，不设 DEPLOY_USER
# Example: DEPLOY_HOST=vultr-server
#   → ssh vultr-server

# --- Direct mode (GitHub Actions) ---
# Example: DEPLOY_HOST=203.0.113.10
#          DEPLOY_USER=root

DEPLOY_HOST=
DEPLOY_USER=
DEPLOY_PORT=22

# SSH private key path (for deploy.sh local usage, optional)
# DEPLOY_SSH_KEY=~/.ssh/id_ed25519

# Remote paths (change if deploying outside /opt/unichat)
# REMOTE_DIR=/opt/unichat

# Health check URL
# HEALTH_URL=https://unichat.makemoney2g.com/health
