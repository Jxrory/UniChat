# Telegram
TELEGRAM_BOT_TOKEN=<your-token>
TELEGRAM_WEBHOOK_SECRET=<your-secret>

# WhatsApp
WA_PHONE_NUMBER_ID=<your-phone-number-id>
WA_TOKEN=<your-whatsapp-token>
WA_WEBHOOK_VERIFY_TOKEN=<your-verify-token>

# Test adapter (only needed when UNICHAT_ENV != production)
TEST_WEBHOOK_SECRET=<your-test-webhook-secret>

# AgentBot
AGENTBOT_URL=<your-agentbot-url>
AGENTBOT_TOKEN=<your-agentbot-token>

# Admin
ADMIN_TOKEN=<your-admin-token>

# Database (optional, default: sqlite:///./unichat.db)
# DATABASE_URL=postgresql://user:pass@localhost/unichat

# Server (optional)
# LOG_LEVEL=DEBUG
